{
  "name": "task-management-frontend",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:open": "powershell -NoProfile -Command \"$env:ELECTRON_RUN_AS_NODE=$null; $env:NODE_ENV='development'; $env:ELECTRON_DEV='true'; $env:ELECTRON_RENDERER_URL='http://localhost:5173'; & 'node_modules\\\\electron\\\\dist\\\\electron.exe' .\"",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:open\"",
    "electron:build": "vite build --config vite.electron.config.js && electron-builder --config electron-builder.yml",
    "electron:build:win": "vite build --config vite.electron.config.js && electron-builder --config electron-builder.yml --win",
    "electron:build:mac": "vite build --config vite.electron.config.js && electron-builder --config electron-builder.yml --mac",
    "electron:build:linux": "vite build --config vite.electron.config.js && electron-builder --config electron-builder.yml --linux",
    "mobile:build": "vite build --config vite.capacitor.config.js",
    "mobile:sync": "npm run mobile:build && npx cap sync",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "mobile:ios": "npm run mobile:sync && npx cap open ios",
    "mobile:run:android": "npm run mobile:sync && npx cap run android",
    "mobile:run:ios": "npm run mobile:sync && npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "axios": "^1.13.2",
    "lucide-react": "^0.577.0",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.9.6",
    "react-select": "^5.10.2",
    "recharts": "^3.5.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.4",
    "wait-on": "^9.0.4"
  }
}
