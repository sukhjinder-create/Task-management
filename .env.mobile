# Mobile build environment variables
# 10.0.2.2 = Android emulator's alias for your PC's localhost
# If testing on a REAL phone (not emulator), replace with your PC's WiFi IP
# e.g. VITE_API_URL=http://192.168.1.100:3000
VITE_API_URL=http://172.16.10.7:3000
VITE_BACKEND_URL=http://172.16.10.7:3000


